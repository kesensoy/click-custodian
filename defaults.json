{
  "version": "1.0.0",
  "tabCloseRules": [
    {
      "id": "aws-oauth-callback",
      "name": "AWS CLI OAuth Callback",
      "urlPattern": "*://127.0.0.1:*/oauth/callback*",
      "matchType": "glob",
      "delay": 3000
    },
    {
      "id": "azure-appverify",
      "name": "Microsoft Azure App Verify (Blank Page)",
      "urlPattern": "https://login.microsoftonline.com/appverify",
      "matchType": "exact",
      "delay": 3000
    },
    {
      "id": "localhost-oauth-callback",
      "name": "Generic Localhost OAuth Callback",
      "urlPattern": "*://localhost:*/callback?code=*",
      "matchType": "glob",
      "delay": 3000
    }
  ],
  "buttonClickRules": []
}
